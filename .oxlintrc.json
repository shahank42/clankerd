{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["unicorn", "typescript", "oxc"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "no-console": "off",
    "no-underscore-dangle": ["warn", { "allow": ["_tag"] }]
  },
  "ignorePatterns": ["node_modules", "dist", "*.d.ts"]
}
